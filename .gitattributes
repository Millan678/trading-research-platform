# Auto detect text files and perform LF normalization
*          text=auto eol=lf

# Python files always use LF
*.py       text eol=lf
*.pyx      text eol=lf
*.pyi      text eol=lf

# Shell scripts
*.sh       text eol=lf
*.bash     text eol=lf

# Config / data
*.yml      text eol=lf
*.yaml     text eol=lf
*.json     text eol=lf
*.toml     text eol=lf
*.ini      text eol=lf
*.cfg      text eol=lf
*.md       text eol=lf
*.txt      text eol=lf
*.csv      text eol=lf

# Markdown with linguist
*.md       linguist-documentation

# Binary — never diff
*.db       binary
*.sqlite   binary
*.png      binary
*.jpg      binary
*.gif      binary
*.woff     binary
*.woff2    binary
*.ttf      binary
*.eot      binary
